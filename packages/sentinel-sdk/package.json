{
  "name": "@beezshield/sentinel",
  "version": "0.1.0",
  "description": "Minimal TypeScript client for Sentinel Alpha (BeezShield) risk decisions",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "keywords": [
    "beezshield",
    "sentinel",
    "risk",
    "x402"
  ],
  "license": "MIT",
  "private": true,
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "~5.6.3",
    "vitest": "~2.1.9"
  }
}
