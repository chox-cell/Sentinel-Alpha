{
  "name": "@beezshield/sentinel",
  "version": "0.1.0",
  "private": false,
  "description": "Minimal TypeScript client for Sentinel Alpha / BeezShield contract risk scoring (x402-aware).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "beezshield",
    "sentinel",
    "x402",
    "risk-score"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "~5.7.2",
    "vitest": "^3.0.5"
  }
}
