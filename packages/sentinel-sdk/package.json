{
  "name": "@beezshield/sentinel",
  "version": "0.1.0",
  "description": "Official BeezShield Sentinel Alpha TypeScript SDK for pre-execution smart-contract risk decisions",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run"
  },
  "keywords": [
    "beezshield",
    "sentinel",
    "x402",
    "ERC-8004",
    "Base",
    "autonomous agents",
    "agent security",
    "smart contract risk",
    "pre-execution"
  ],
  "license": "MIT",
  "private": true,
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "~5.6.3",
    "vitest": "~2.1.9"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chox-cell/Sentinel-Alpha.git"
  },
  "homepage": "https://beezshield.com",
  "bugs": {
    "url": "https://github.com/chox-cell/Sentinel-Alpha/issues"
  }
}
